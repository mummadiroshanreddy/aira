# Copy this file to .env.development and .env.production
# Never commit real API keys to git

# Environment
REACT_APP_ENV=development

# API URL — local dev uses Express server, production uses PHP proxy
REACT_APP_API_URL=http://localhost:3001/api

# App Config
REACT_APP_APP_NAME=ARIA Copilot
REACT_APP_VERSION=1.0.0
REACT_APP_MAX_TOKENS=1200
REACT_APP_MODEL=claude-3-5-sonnet-20241022
REACT_APP_RATE_LIMIT=100
REACT_APP_SESSION_TIMEOUT=7200000

# ─── NEVER PUT ANTHROPIC KEY IN ANY REACT_APP_ VARIABLE ───
# REACT_APP_ variables are exposed to the browser.
# Put your Anthropic API key ONLY in:
# - server/.env (for local Express development server)
# - public/.env.php (for Hostinger production)
# ───────────────────────────────────────────────────────────
